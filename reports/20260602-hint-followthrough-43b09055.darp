    "algorithm": {
      "engine": {
        "name": "pandas",
        "version": "2.2.3",
        "language": "python"
      },
      "parameters": {
        "session_metric": "first_lookup",
        "min_sessions": 5,
        "classification_categories": [
          "specific_n",
          "find_n",
          "grep_n",
          "other_n",
          "no_api_n"
        ],
        "capture": {
          "api_command": "api.py",
          "packages_path": "packages/",
          "vibe_pattern": "vibe",
          "memory_tool": "mcp__ccd_session__search_session_transcripts",
          "trace_pattern": "hint_trace_*.jsonl",
          "smoke_prefix": "smoke",
          "packages_tools": [
            "Glob",
            "Grep",
            "Read"
          ],
          "specific_families": [
            "component",
            "discover",
            "docs",
            "frontend",
            "ls",
            "model",
            "which"
          ],
          "generic_families": [
            "find",
            "grep"
          ]
        },
        "algorithm_map": {
          "next": "next",
          "window": "window",
          "first": "first",
          "rate": "rate"
        },
        "source_map": {
          "event_field": "event",
          "hint_value": "darp_hint",
          "action_value": "darp_action",
          "ts_field": "ts",
          "ts_scale": 1.0,
          "source_field": "source",
          "synthetic_field": "synthetic",
          "try_next_field": "try_next",
          "tool_field": "tool",
          "invocation_field": "invocation"
        },
        "thresholds": {
          "noise_band": 10.0,
          "warn_band": 20.0,
          "div_max": 20.0
        },
        "baseline_commit": "43b09055d42058934f0bcdc620b2ccbdfe47ed7f",
        "baseline_values": {
          "greplast_gate": 41.0,
          "read_gate": 17.0
        },
        "anchor": {
          "calendars": [
            "https://a.pool.opentimestamps.org/digest",
            "https://b.pool.opentimestamps.org/digest",
            "https://c.pool.opentimestamps.org/digest"
          ]
        }
      },
      "definitions": {
        "greplast_gate": {
          "algorithm": "next",
          "trigger_source": "greplast_gate",
          "description": "Agent reached for grep/find before trying a specific API endpoint.",
          "followed_if": "Next tool call invokes api.py with a suggested endpoint family.",
          "modified_if": "Next tool call invokes api.py but a different endpoint than suggested.",
          "routed_if": "Next tool call is Read, Glob, Grep, or Bash instead of api.py.",
          "notes": "Matched-pair experiment (variant A vs B) is the next planned intervention."
        },
        "read_gate": {
          "algorithm": "window",
          "trigger_source": "read_gate",
          "window": "10",
          "echo_dedup": "true",
          "echo_dedup_field": "searched",
          "echo_dedup_strip_prefix": "Read",
          "divergence_max": "20.0",
          "description": "Agent read a file under packages/ without a preceding api.py call in the session.",
          "followed_if": "An api.py file? call occurs within window tool calls after the gate.",
          "modified_if": "Any api.py call occurs within window tool calls after the gate.",
          "routed_if": "No api.py call within window tool calls after the gate.",
          "notes": "Two views: per-gate% (tuning metric) and per-session% (sanity check). Divergence >20pts between views indicates gate-cluster density, not regression."
        },
        "first_lookup": {
          "algorithm": "first",
          "description": "Per-session: was the first structured API lookup a specific endpoint rather than a generic one?",
          "followed_if": "First non-vibe api.py call in the session uses a specific endpoint family.",
          "modified_if": "N/A \u2014 binary session-level metric; no modified state.",
          "routed_if": "First non-vibe api.py call uses grep? or find? (generic search).",
          "notes": "Not hint-driven. Acts as the primary behavioral trend metric. No control arm needed \u2014 the first call is uninfluenced by any gate or hint."
        },
        "api_empty": {
          "algorithm": "next",
          "trigger_source": "api_empty",
          "description": "api.py returned an empty result. Hint suggests a narrower or alternative endpoint.",
          "followed_if": "Next tool call invokes api.py with a suggested endpoint family.",
          "modified_if": "Next tool call invokes api.py with a different endpoint/query than suggested.",
          "routed_if": "Next tool call is Read, Glob, Grep, or Bash instead of api.py.",
          "notes": "Noisy single-point signal. Act only on >10pt sustained shift across multiple checks."
        }
      }
    }
  },
